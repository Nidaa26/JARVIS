# Copy this file to .env and fill in your key. Never commit .env.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Optional overrides (defaults shown) ---
# ASSISTANT_MODEL=claude-opus-4-8
# ASSISTANT_MAX_TOKENS=8000
# ASSISTANT_EFFORT=low            # low | medium | high | max (low = fastest replies)
# ASSISTANT_HISTORY_LIMIT=20      # messages of context sent per request
# ASSISTANT_VOICE=0               # 1 to enable voice by default
# ASSISTANT_TTS_RATE=185          # speech speed (words per minute)
# ASSISTANT_STT_TIMEOUT=6         # seconds to wait for speech to start
# ASSISTANT_STT_PHRASE_LIMIT=15   # max seconds per utterance
# ASSISTANT_DATA_DIR=~/.group-project-assistant
# ASSISTANT_API_RETRIES=3
# ASSISTANT_REQUEST_TIMEOUT=120
# LOG_LEVEL=INFO
